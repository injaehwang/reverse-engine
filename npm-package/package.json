{
  "name": "reverse-engine",
  "version": "0.8.0",
  "description": "웹 서비스 역분석 자동화 도구 - 소스코드 분석, 문서 생성, 테스트 자동화",
  "keywords": [
    "reverse-engineering",
    "code-analysis",
    "documentation",
    "test-generation",
    "crawler",
    "static-analysis",
    "ast",
    "react",
    "vue",
    "angular",
    "excel"
  ],
  "author": "injaehwang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/injaehwang/revers-eng"
  },
  "type": "module",
  "bin": {
    "reverse-engine": "dist/cli/index.js",
    "reverseng": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "prepublishOnly": "npm run build",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "@babel/types": "^7.26.0",
    "commander": "^13.0.0",
    "exceljs": "^4.4.0",
    "chalk": "^5.4.0",
    "ora": "^8.2.0",
    "playwright": "^1.49.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0"
  },
  "optionalDependencies": {
    "reverse-engine-win32-x64": "0.2.0",
    "reverse-engine-win32-arm64": "0.2.0",
    "reverse-engine-linux-x64": "0.2.0",
    "reverse-engine-linux-arm64": "0.2.0",
    "reverse-engine-darwin-x64": "0.2.0",
    "reverse-engine-darwin-arm64": "0.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
